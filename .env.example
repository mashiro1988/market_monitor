# market_monitor .env 模板
# 真实凭据写到 .env（已 gitignore）。本文件提交进库做参考。

# ============================================================
# 现有：代理（按需打开）
# ============================================================
# PROXY_URL=http://127.0.0.1:4780

# ============================================================
# 现有：API keys
# ============================================================
# DEEPSEEK_API_KEY=
# APP_AUTH_TOKEN=
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_REASONER_MODEL=deepseek-v4-pro

# ============================================================
# 现有：企业微信告警
# ============================================================
# WECHAT_WORK_WEBHOOK=

# ============================================================
# 现有：数据库 / 扫描配置（一般用默认就行）
# ============================================================
# DATABASE_URL=sqlite:///market_monitor.db
# SCAN_ROLLING_BACKFILL_INTERVALS=2

# ============================================================
# 日志（默认同时输出到 stderr 和 logs/market_monitor.log）
# ============================================================
LOG_LEVEL=INFO
LOG_FILE_ENABLED=1
LOG_DIR=logs
LOG_FILE_NAME=market_monitor.log
LOG_ROTATION=20 MB
LOG_RETENTION=14 days
LOG_COMPRESSION=zip

# ============================================================
# 新增（Phase 1）：远程数据源（BMAC SFTP）
# ============================================================
# 服务器 SSH 接入。优先用私钥认证，REMOTE_KEY_PATH 和 REMOTE_PASSWORD 至少要设一个。
# 示例文件只放占位符；真实 host/user/password/key 放本机 .env，不要提交进仓库。
REMOTE_HOST=your-server.example.com
REMOTE_PORT=22
REMOTE_USER=market-monitor
# 推荐：本地 ssh-keygen 后 ssh-copy-id 推上去，然后这里填私钥路径
# REMOTE_KEY_PATH=C:\Users\Lenovo\.ssh\id_market_monitor
# 临时方案：密码登录（设置完私钥后立刻清空 + 服务器侧禁用密码登录）
REMOTE_PASSWORD=
# 默认校验 SSH known_hosts；如需指定文件，填 REMOTE_KNOWN_HOSTS。
# REMOTE_KNOWN_HOSTS=C:\Users\Lenovo\.ssh\known_hosts
# 临时调试新主机才设 1；生产保持 0。
REMOTE_ALLOW_UNKNOWN_HOST=0
# 数据根目录（一般不动）
REMOTE_DATA_ROOT=/root/data_center/data/
# BMAC hour offset 子目录，可选 10m / 20m / 30m / 35m
REMOTE_OFFSET=30m
# remote_data_cycle 轮询节奏（秒）。Phase 1 数据是小时级,默认 1h 轮询匹配;
# Phase 4 加入 5min 粒度 focal symbol candle 后,这个值要降到 60s 或者改 per-dataset.
REMOTE_PULLER_POLL_SECONDS=3600

# 远程板块管道健康告警：remote_data_cycle 异常、SFTP 连续失败、SQLite WAL 过大时推企业微信。
REMOTE_MONITORING_ENABLED=1
REMOTE_MONITOR_ALERT_COOLDOWN_MINUTES=60
REMOTE_MONITOR_SFTP_FAILURE_THRESHOLD=3
REMOTE_MONITOR_WAL_MAX_MB=512

# ============================================================
# 新增（Phase 1）：CoinMarketCap 板块映射
# ============================================================
CMC_API_KEY=
# 板块映射本地缓存有效期（天）。改 SECTOR_WHITELIST 后跑 `python run.py refresh-sectors` 强制刷新
CMC_CACHE_TTL_DAYS=7
# 默认 CMC API 直连（不走代理）—— CMC 在国内可直接访问，走 Clash 等代理反而 SSL 易掉线。
# 如果你在墙外/出口受限要强行走代理，设 1。
# CMC_USE_PROXY=0
