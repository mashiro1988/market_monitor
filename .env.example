# market_monitor .env 模板
# 真实凭据写到 .env（已 gitignore）。本文件提交进库做参考。

# ============================================================
# 现有：代理（按需打开）
# ============================================================
# PROXY_URL=http://127.0.0.1:4780

# ============================================================
# 现有：API keys
# ============================================================
# DUNE_API_KEY=
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_REASONER_MODEL=deepseek-v4-pro

# ============================================================
# 现有：企业微信告警
# ============================================================
# WECHAT_WORK_WEBHOOK=

# ============================================================
# 现有：数据库 / 扫描配置（一般用默认就行）
# ============================================================
# DATABASE_URL=sqlite:///market_monitor.db
# SCAN_ROLLING_BACKFILL_INTERVALS=2

# ============================================================
# 新增（Phase 1）：远程数据源（BMAC SFTP）
# ============================================================
# 服务器 SSH 接入。优先用私钥认证，REMOTE_KEY_PATH 和 REMOTE_PASSWORD 至少要设一个。
REMOTE_HOST=47.243.252.92
REMOTE_PORT=22
REMOTE_USER=root
# 推荐：本地 ssh-keygen 后 ssh-copy-id 推上去，然后这里填私钥路径
# REMOTE_KEY_PATH=C:\Users\Lenovo\.ssh\id_market_monitor
# 临时方案：密码登录（设置完私钥后立刻清空 + 服务器侧禁用密码登录）
REMOTE_PASSWORD=
# 数据根目录（一般不动）
REMOTE_DATA_ROOT=/root/data_center/data/
# BMAC hour offset 子目录，可选 10m / 20m / 30m / 35m
REMOTE_OFFSET=30m
# remote_puller 轮询节奏（秒）
REMOTE_PULLER_POLL_SECONDS=60

# ============================================================
# 新增（Phase 1）：CoinMarketCap 板块映射
# ============================================================
CMC_API_KEY=
# 板块映射本地缓存有效期（天）。改 SECTOR_WHITELIST 后跑 `python run.py refresh-sectors` 强制刷新
CMC_CACHE_TTL_DAYS=7
# 默认 CMC API 直连（不走代理）—— CMC 在国内可直接访问，走 Clash 等代理反而 SSL 易掉线。
# 如果你在墙外/出口受限要强行走代理，设 1。
# CMC_USE_PROXY=0
